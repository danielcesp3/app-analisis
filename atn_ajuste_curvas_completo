// tabla dinámica
function addRow(mod,x="",y=""){
  const tb=document.querySelector(`#${mod}-tbl tbody`);
  const tr=document.createElement("tr");
  tr.innerHTML=`<td><input type="text" value="${x}"></td>
                <td><input type="text" value="${y}"></td>
                <td><button class="del-row" onclick="this.closest('tr').remove()">✕</button></td>`;
  tb.appendChild(tr);
}
function clearTbl(mod){document.querySelector(`#${mod}-tbl tbody`).innerHTML="";}
function parseNums(str){
  return str.replace(/;/g,",").replace(/\s+/g,",").split(",").filter(s=>s.trim()!=="").map(Number);
}
function cargarTexto(mod){
  const xs=parseNums(document.getElementById(`${mod}-x`).value);
  const ys=parseNums(document.getElementById(`${mod}-y`).value);
  if(xs.some(isNaN)||ys.some(isNaN)){return alerta(mod,"Hay valores no numéricos en X o Y.");}
  if(xs.length!==ys.length){return alerta(mod,`X tiene ${xs.length} y Y tiene ${ys.length} valores: deben coincidir.`);}
  clearTbl(mod); xs.forEach((x,i)=>addRow(mod,x,ys[i])); ocultarAlerta(mod);
}
function leerTabla(mod){
  const filas=document.querySelectorAll(`#${mod}-tbl tbody tr`);
  const x=[],y=[];
  filas.forEach(f=>{
    const inp=f.querySelectorAll("input");
    const vx=inp[0].value.trim(), vy=inp[1].value.trim();
    if(vx===""&&vy==="")return;
    const nx=Number(vx),ny=Number(vy);
    if(isNaN(nx)||isNaN(ny))throw new Error(`Celda no numérica: ("${vx}", "${vy}").`);
    x.push(nx);y.push(ny);
  });
  if(x.length!==y.length)throw new Error("X e Y deben tener la misma longitud.");
  if(x.length<2)throw new Error("Ingresa al menos 2 puntos.");
  return [x,y];
}
function alerta(mod,msg){const a=document.getElementById(`${mod}-alert`);a.textContent="⚠ "+msg;a.style.display="block";}
function ocultarAlerta(mod){document.getElementById(`${mod}-alert`).style.display="none";}

function ejemploReg(){
  document.getElementById("reg-x").value="1, 2, 3, 4, 5, 6, 7";
  document.getElementById("reg-y").value="0.5, 1.7, 3.4, 5.7, 8.4, 11.3, 14.4";
  cargarTexto("reg");
}
/* ---- REGRESIÓN ---- */
function calcularReg(todos){
  ocultarAlerta("reg");
  let x,y;
  try{[x,y]=leerTabla("reg");}catch(e){return alerta("reg",e.message);}

  let seleccion;
  if(todos){
    seleccion=Object.keys(METODOS_REG);
    document.querySelectorAll("#reg-metodos input").forEach(c=>c.checked=true);
  }else{
    seleccion=[...document.querySelectorAll("#reg-metodos input:checked")].map(c=>c.value);
  }
  if(seleccion.length===0)return alerta("reg","Selecciona al menos un método.");

  const series=[{type:"scatter",x,y,color:"#e8eef7",label:"Datos originales"}];
  const xc=linspace(Math.min(...x),Math.max(...x),300);
  const resultados=[], errores=[];
  seleccion.forEach(n=>{
    try{
      const res=METODOS_REG[n].fn(x,y);
      resultados.push(res);
      series.push({type:"line",x:xc,y:xc.map(res.fn),color:METODOS_REG[n].color,
        label:`${n} (R²=${res.r2.toFixed(3)})`});
    }catch(e){errores.push(`• ${n}: ${e.message}`);}
  });
  if(errores.length)alerta("reg",errores.join("  "));

  dibujar(document.getElementById("reg-canvas"),series,{xlabel:"x",ylabel:"y"});

  // tabla de resultados con resaltado del mejor R²
  const tb=document.querySelector("#reg-results tbody"); tb.innerHTML="";
  if(resultados.length){
    let best=resultados.reduce((a,b)=>(isNaN(b.r2)?a:(b.r2>(isNaN(a.r2)?-1:a.r2)?b:a)));
    resultados.forEach(r=>{
      const tr=document.createElement("tr"); if(r===best)tr.className="best";
      tr.innerHTML=`<td>${r.nombre}${r===best?'<span class="tag-best">MEJOR</span>':''}</td>
        <td>${r.ecuacion}</td><td>${r.r.toFixed(4)}</td><td>${r.r2.toFixed(4)}</td><td>${r.syx.toFixed(4)}</td>`;
      tb.appendChild(tr);
    });
    const steps=document.getElementById("reg-steps");
    steps.style.display="block"; steps.textContent=resultados.map(r=>r.pasos).join("\n\n");
  }else{
    tb.innerHTML='<tr><td colspan="5" style="color:var(--muted)">Ningún método aplicó a estos datos.</td></tr>';
  }
}

